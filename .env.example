# Postgres (Prisma)
# For Neon/Supabase in app runtime, prefer the pooled/pgbouncer URL here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct connection for Prisma migrate/introspection (non-pooled).
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# App auth base URL and secret.
# Use the same host you log into locally, e.g. http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_a_real_random_secret"

# Stripe test mode keys and products.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ULTRA="price_..."

# Local-only convenience for server route testing without a browser session.
# When true outside production, billing API routes can use DEV_USER_EMAIL / dev_user.
DEV_BYPASS_AUTH="false"
DEV_USER_EMAIL="dev@local"

# AI detector service base URL (path defaults to /detect)
# Local default in code: http://127.0.0.1:8000
DETECTOR_URL="http://127.0.0.1:8000"
# Backward-compatible alias used by existing deployments
PY_DETECTOR_URL="http://127.0.0.1:8000/detect"
# Local-only convenience: allows /api/ai-detector without auth in non-production
AI_DETECTOR_DEV_BYPASS_AUTH="0"

# Promo code hashing secret (required for promo:create and /api/billing/redeem)
# Must be a real random secret. Placeholder/default values are rejected.
PROMO_CODE_SECRET="Hello_world"

# Optional internal account allowlist for permanent premium bypass (comma-separated user ids/emails)
# PREMIUM_BYPASS_USER_IDS="me@example.com,internal@example.com"

# Study generation uses the first available provider in this order:
# GROQ -> DEEPSEEK -> KIMI
# GROQ_API_KEY=""
# DEEPSEEK_API_KEY=""
# KIMI_API_KEY=""
